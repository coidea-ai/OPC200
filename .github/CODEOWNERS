.pylintrc @coidea-ai/maintainers
.eslintrc* @coidea-ai/maintainers
.prettierrc* @coidea-ai/maintainers

# Git忽略文件
.gitignore @coidea-ai/maintainers
.gitattributes @coidea-ai/maintainers

# =============================================================================
# 训练和AI（Owner审批）
# =============================================================================

/insclaw-training/ @coidea-ai/owners
/models/ @coidea-ai/owners
/training-data/ @coidea-ai/owners

