# OPC200 CODEOWNERS
# 
# 代码所有权配置 - 定义谁负责审查哪些代码
# 格式: <pattern> <owner1> <owner2> ...
# 最后匹配的规则生效

# =============================================================================
# 默认所有者
# =============================================================================
* @danny

# =============================================================================
# 核心技能（AI Agent功能）
# =============================================================================
/skills/ @danny
/skills/opc-journal-suite/ @danny
/skills/**/SKILL.md @danny

# =============================================================================
# 后端核心
# =============================================================================
/src/core/ @danny
/src/api/ @danny
/src/models/ @danny

# =============================================================================
# 安全敏感（需要严格审查）
# =============================================================================
/src/auth/ @danny
/src/permissions/ @danny
/src/encryption/ @danny
/security/ @danny
*.key @danny
*.pem @danny

# =============================================================================
# CI/CD和部署
# =============================================================================
/.github/workflows/ @danny
Dockerfile* @danny
docker-compose*.yml @danny

# =============================================================================
# 配置
# =============================================================================
/config/ @danny
*.yaml @danny
*.yml @danny

# =============================================================================
# 文档
# =============================================================================
/docs/ @danny
*.md @danny
README.md @danny

# =============================================================================
# 测试
# =============================================================================
/tests/ @danny
