          "expr": "{__name__=~\"cpu_usage|memory_usage|disk_usage\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "用户指标列表",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "indexByName": {
              "Time": 0,
              "job": 1,
              "__name__": 2,
              "Value": 3
            },
            "renameByName": {
              "__name__": "Metric",
              "job": "User"
            }
          }
        }
