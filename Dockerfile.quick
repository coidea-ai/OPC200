# OPC200 最简 Dockerfile - 仅用于验证容器能否运行
FROM python:3.12-alpine

WORKDIR /app

# 复制简单测试文件
COPY README.md ./

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "print('OK')" || exit 1

EXPOSE 8000

CMD ["python", "-c", "print('OPC200 Container Ready'); import time; time.sleep(3600)"]
